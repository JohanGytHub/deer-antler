---
import CollectionLayout from '../../layouts/CollectionLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { fetchProducts, filterByCollection } from '../../data/products';

const allProducts = await fetchProducts();
const products = filterByCollection(allProducts, 'Unique');
---

<CollectionLayout
  title="Unique Deer Antler Jewelry | One-of-a-Kind Antler Pieces"
  description="One-of-a-kind deer antler jewelry handcrafted in Minneapolis, USA. Each unique piece exists only once — naturally shed antler in extraordinary combinations. Order at Jewelry by Johan."
  heading="Unique Antler Pieces"
  subheading="These pieces exist only once. When they are gone, they are gone. Each one is a singular expression of natural antler paired with extraordinary materials — made in our Minneapolis workshop."
  collectionName="Unique Pieces"
  collectionPath="/unique"
  productCount={products.length}
>

  <!-- One-of-a-kind notice -->
  <div class="mb-8 bg-[#1c2a1b] border border-[#b8860b]/30 px-5 py-4 flex items-start gap-3">
    <svg class="w-5 h-5 text-[#b8860b] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
    </svg>
    <div>
      <p class="text-sm font-semibold text-[#d4b896] mb-0.5">One-of-a-Kind Pieces</p>
      <p class="text-xs text-[#b8b5ae] leading-snug">Every item in this collection is unique — when it sells, it cannot be reproduced. If you see something you love, don't wait. All pieces are ordered at Jewelry by Johan.</p>
    </div>
  </div>

  {products.length > 0 ? (
    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-5">
      {products.map((product, i) => (
        <ProductCard product={product} eager={i < 4} />
      ))}
    </div>
  ) : (
    <div class="text-center py-20">
      <p class="font-serif text-2xl text-[#d4b896] mb-3">Unique Collection Coming Soon</p>
      <p class="text-[#b8b5ae] mb-6">Our unique antler pieces are being curated. Visit Jewelry by Johan for current availability.</p>
      <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener noreferrer" class="btn-gold">View at Jewelry by Johan</a>
    </div>
  )}

  <section class="mt-16 border-t border-[#2e3d2d] pt-12">
    <div class="max-w-3xl">
      <h2 class="font-serif text-2xl text-[#f0ede8] mb-4">About Our Unique Antler Pieces</h2>
      <div class="prose-antler text-sm">
        <p>Our unique collection gathers the most extraordinary one-of-a-kind antler jewelry from our workshop — pieces where a particularly beautiful section of antler, an unusual material combination, or an experimental design came together in a way that simply cannot be repeated.</p>
        <p>Because antler is a natural material, each section of it is different. Occasionally, a piece of antler yields a pattern, color gradient, or cellular texture so exceptional that our craftsmen build a ring or jewelry piece specifically around it. These are the pieces you find here.</p>
        <p>Once sold, a unique piece is gone. If you have your eye on something, we recommend reaching out to Jewelry by Johan promptly. All orders are placed at <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener noreferrer">jewelrybyjohan.com</a>.</p>
        <p>If you don't find exactly what you're looking for, consider our <a href="/custom">trophy antler custom rings</a> page — where you can send your own antler to be crafted into something entirely your own.</p>
      </div>
    </div>
  </section>

</CollectionLayout>