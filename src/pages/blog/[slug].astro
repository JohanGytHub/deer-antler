---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { blogPosts } from '../../data/blog';
import type { BlogPost } from '../../data/blog';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

interface Props { post: BlogPost; }
const { post } = Astro.props;

const SITE_URL = 'https://deer-antler.jewelry';
const JBJ_URL  = 'https://jewelrybyjohan.com';

// Prev / next posts
const idx  = blogPosts.findIndex((p) => p.slug === post.slug);
const prev = idx > 0                      ? blogPosts[idx - 1] : null;
const next = idx < blogPosts.length - 1   ? blogPosts[idx + 1] : null;

// Related posts — same category, exclude self, max 3
const related = blogPosts
  .filter((p) => p.category === post.category && p.slug !== post.slug)
  .slice(0, 3);

// Article JSON-LD — includes dateModified, wordCount, image, publisher.logo
const articleSchema = {
  '@context':   'https://schema.org',
  '@type':      'Article',
  headline:     post.title,
  description:  post.excerpt,
  datePublished: post.datePublished,
  dateModified:  post.dateModified,
  wordCount:     post.wordCount,
  image: {
    '@type': 'ImageObject',
    url:     post.image,
    alt:     post.imageAlt,
  },
  author: {
    '@type': 'Organization',
    name:    'Jewelry by Johan',
    url:     JBJ_URL,
  },
  publisher: {
    '@type': 'Organization',
    name:    'Jewelry by Johan',
    url:     JBJ_URL,
    logo: {
      '@type': 'ImageObject',
      url:     `${JBJ_URL}/cdn/shop/files/JBJ-logo.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id':   `${SITE_URL}/blog/${post.slug}`,
  },
  url: `${SITE_URL}/blog/${post.slug}`,
};

// BreadcrumbList for this blog post
const breadcrumbs = [
  { name: 'Home', item: `${SITE_URL}/` },
  { name: 'Blog', item: `${SITE_URL}/blog` },
  { name: post.title, item: `${SITE_URL}/blog/${post.slug}` },
];

// Estimated reading time
const readTime = Math.max(1, Math.round(post.wordCount / 200));

// Meta title / description
const metaTitle = `${post.title.slice(0, 55)} | deer-antler.jewelry`;
const metaDesc  = post.excerpt.slice(0, 160);
---

<BaseLayout
  title={metaTitle}
  description={metaDesc}
  ogImage={post.image}
  breadcrumbs={breadcrumbs}
>
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </slot>

  <Nav />

  <!-- Post header -->
  <header class="bg-[#162114] border-b border-[#2e3d2d] py-14 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-xs font-sans text-[#7a7770] flex-wrap">
          <li><a href="/" class="hover:text-[#d4b896] transition-colors">Home</a></li>
          <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li><a href="/blog" class="hover:text-[#d4b896] transition-colors">Blog</a></li>
          <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-[#d4b896] truncate max-w-[180px]" aria-current="page">{post.title}</li>
        </ol>
      </nav>

      <!-- Category + meta -->
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="text-xs font-sans font-semibold uppercase tracking-widest text-[#b8860b]">{post.category}</span>
        <span class="text-[#2e3d2d]">·</span>
        <time class="text-xs text-[#7a7770] font-sans" datetime={post.datePublished}>
          {new Date(post.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-[#2e3d2d]">·</span>
        <span class="text-xs text-[#7a7770] font-sans">{readTime} min read</span>
      </div>

      <!-- Title -->
      <h1 class="font-serif text-[clamp(1.8rem,4.5vw,3rem)] text-[#f0ede8] leading-tight mb-5 animate-fade-up">
        {post.title}
      </h1>

      <!-- Excerpt -->
      <p class="text-base sm:text-lg text-[#b8b5ae] leading-relaxed animate-fade-up delay-100 max-w-2xl">
        {post.excerpt}
      </p>

    </div>
  </header>

  <!-- Article body -->
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">

    <article class="prose-antler" set:html={post.body} />

    <!-- Disclaimer -->
    <div class="mt-10 bg-[#162114] border border-[#2e3d2d] p-4">
      <p class="text-xs text-[#7a7770] leading-snug">
        <strong class="text-[#b8b5ae]">Note:</strong> Some content on this site is AI-assisted and reviewed for accuracy. For the most current product information and pricing, visit <a href={JBJ_URL} target="_blank" rel="noopener noreferrer" class="text-[#d4b896] hover:underline">jewelrybyjohan.com</a>. See our <a href="/disclaimer" class="text-[#d4b896] hover:underline">content disclaimer</a>.
      </p>
    </div>

    <!-- CTA -->
    <div class="mt-10 bg-[#1c2a1b] border border-[#2e3d2d] p-7 text-center">
      <p class="font-serif text-xl text-[#d4b896] mb-3">Ready to order?</p>
      <p class="text-sm text-[#b8b5ae] mb-5 leading-relaxed">All antler rings are ordered at Jewelry by Johan — handcrafted in Minneapolis, USA. Free laser engraving up to 25 characters included.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="https://jewelrybyjohan.com/collections/deer-antler-rings" target="_blank" rel="noopener noreferrer" class="btn-gold">View at Jewelry by Johan</a>
        <a href="/sizing-guide" class="btn-outline">Ring Sizing Guide</a>
      </div>
    </div>

    <!-- Prev / Next navigation -->
    {(prev || next) && (
      <nav class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4" aria-label="Blog post navigation">
        {prev && (
          <a href={`/blog/${prev.slug}`} class="card p-5 group flex flex-col gap-2">
            <span class="text-xs font-sans text-[#7a7770] flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
              Previous
            </span>
            <span class="font-serif text-sm text-[#d4b896] group-hover:text-[#f0ede8] transition-colors leading-snug line-clamp-2">{prev.title}</span>
          </a>
        )}
        {next && (
          <a href={`/blog/${next.slug}`} class={`card p-5 group flex flex-col gap-2 ${!prev ? 'sm:col-start-2' : ''}`}>
            <span class="text-xs font-sans text-[#7a7770] flex items-center gap-1 sm:justify-end">
              Next
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
            <span class="font-serif text-sm text-[#d4b896] group-hover:text-[#f0ede8] transition-colors leading-snug line-clamp-2 sm:text-right">{next.title}</span>
          </a>
        )}
      </nav>
    )}

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="mt-14 pt-10 border-t border-[#2e3d2d]">
        <h2 class="font-serif text-2xl text-[#f0ede8] mb-6">Related Articles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {related.map((p) => (
            <article class="card group p-5 flex flex-col gap-3">
              <span class="text-[0.65rem] font-sans font-semibold uppercase tracking-widest text-[#b8860b]">{p.category}</span>
              <h3 class="font-serif text-sm text-[#d4b896] group-hover:text-[#f0ede8] transition-colors leading-snug flex-1">
                <a href={`/blog/${p.slug}`}>{p.title}</a>
              </h3>
              <a href={`/blog/${p.slug}`} class="text-xs font-sans text-[#b8860b] hover:text-[#d4b896] flex items-center gap-1 mt-auto transition-colors">
                Read
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Back to blog -->
    <div class="mt-10 text-center">
      <a href="/blog" class="btn-outline text-sm">← Back to Blog</a>
    </div>

  </main>

  <Footer />
</BaseLayout>