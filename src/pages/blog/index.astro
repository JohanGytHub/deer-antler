---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { blogPosts } from '../../data/blog';

// Get unique categories
const categories = ['All', ...Array.from(new Set(blogPosts.map((p) => p.category))).sort()];

// Sort posts newest first
const sorted = [...blogPosts].sort(
  (a, b) => new Date(b.datePublished).getTime() - new Date(a.datePublished).getTime()
);
---

<BaseLayout
  title="Deer Antler Ring Blog | Care, Buying Guides & Trophy Antler"
  description="Expert guides on deer antler rings — care, sizing, buying guides, trophy antler custom rings, material comparisons, and wedding ideas. From Jewelry by Johan."
>
  <Nav />

  <header class="bg-[#162114] border-b border-[#2e3d2d] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-xs font-sans text-[#7a7770]">
          <li><a href="/" class="hover:text-[#d4b896] transition-colors">Home</a></li>
          <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-[#d4b896]" aria-current="page">Blog</li>
        </ol>
      </nav>
      <h1 class="font-serif text-[clamp(2rem,5vw,3.5rem)] text-[#f0ede8] mb-3 animate-fade-up">
        The Deer Antler Journal
      </h1>
      <p class="text-lg text-[#b8b5ae] max-w-2xl animate-fade-up delay-100">
        Expert guides on antler rings, care, sizing, trophy antler customs, material comparisons, and everything you need to know before you order.
      </p>
      <p class="text-sm text-[#7a7770] mt-3 animate-fade-up delay-200">{blogPosts.length} articles</p>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">

    <!-- Category filter -->
    <div class="mb-10 flex flex-wrap gap-2">
      {categories.map((cat, i) => (
        <button
          data-cat={cat}
          class={`cat-btn px-3 py-1.5 text-xs font-sans font-medium border transition-colors duration-150 ${i === 0 ? 'border-[#b8860b] text-[#b8860b] bg-[#b8860b]/10' : 'border-[#2e3d2d] text-[#7a7770] hover:border-[#b8860b] hover:text-[#d4b896]'}`}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Posts grid -->
    <div id="posts-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((post) => (
        <article
          data-category={post.category}
          class="post-card card group flex flex-col"
        >
          <div class="p-6 flex flex-col gap-3 flex-1">
            <div class="flex items-center justify-between gap-2 flex-wrap">
              <span class="text-[0.65rem] font-sans font-semibold uppercase tracking-widest text-[#b8860b]">
                {post.category}
              </span>
              <time class="text-[0.65rem] text-[#7a7770] font-sans" datetime={post.datePublished}>
                {new Date(post.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>

            <h2 class="font-serif text-lg text-[#d4b896] group-hover:text-[#f0ede8] transition-colors leading-snug">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h2>

            <p class="text-sm text-[#b8b5ae] leading-relaxed flex-1 line-clamp-3">
              {post.excerpt}
            </p>

            <div class="flex items-center justify-between mt-auto pt-3 border-t border-[#2e3d2d]">
              <span class="text-xs text-[#7a7770]">{post.wordCount.toLocaleString()} words</span>
              <a href={`/blog/${post.slug}`}
                class="text-xs font-sans font-semibold uppercase tracking-wider text-[#b8860b] flex items-center gap-1 hover:text-[#d4b896] transition-colors">
                Read
                <svg class="w-3 h-3 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-posts" class="hidden text-center py-16">
      <p class="font-serif text-2xl text-[#d4b896] mb-3">No posts in this category yet</p>
      <button data-cat="All" class="cat-btn btn-outline text-sm mt-4">Show all posts</button>
    </div>

  </main>

  <Footer />
</BaseLayout>

<script>
  const buttons   = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards     = document.querySelectorAll<HTMLElement>('.post-card');
  const noPosts   = document.getElementById('no-posts');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat ?? 'All';

      // Update active button styles
      buttons.forEach((b) => {
        b.classList.remove('border-[#b8860b]', 'text-[#b8860b]', 'bg-[#b8860b]/10');
        b.classList.add('border-[#2e3d2d]', 'text-[#7a7770]');
      });
      btn.classList.add('border-[#b8860b]', 'text-[#b8860b]', 'bg-[#b8860b]/10');
      btn.classList.remove('border-[#2e3d2d]', 'text-[#7a7770]');

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const match = cat === 'All' || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      noPosts?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
