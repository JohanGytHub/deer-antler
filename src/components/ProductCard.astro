---
import type { Product } from '../types/product';
import { getProductAlt, getProductImageSrc, getProductUrl, getLocalProductUrl } from '../data/products';

export interface Props {
  product: Product;
  /** Show the "Natural Antler" badge — default true */
  showBadge?: boolean;
  /** Eager-load the image (use for above-the-fold cards) */
  eager?: boolean;
}

const { product, showBadge = true, eager = false } = Astro.props;

// getProductAlt ALWAYS returns a non-empty string (trim fallback to product.title)
const alt      = getProductAlt(product);
const src      = getProductImageSrc(product);
const localUrl = getLocalProductUrl(product);   // local detail page
const jbjUrl   = getProductUrl(product);         // JBJ order page (CTA only)

// Detect combination materials from title / tags for secondary badge
const titleLower = product.title.toLowerCase();
const hasMeteor  = titleLower.includes('meteorite');
const hasDinoBone = titleLower.includes('dinosaur') || titleLower.includes('dino');
const hasWood    = titleLower.includes('wood') || titleLower.includes('koa') || titleLower.includes('whiskey');
const hasTurquoise = titleLower.includes('turquoise');
const hasOpal    = titleLower.includes('opal');
const isElk      = titleLower.includes('elk') || titleLower.includes('moose');

let comboBadge = '';
if (hasMeteor)    comboBadge = 'Antler + Meteorite';
else if (hasDinoBone) comboBadge = 'Antler + Dino Bone';
else if (hasWood) comboBadge = 'Antler + Wood';
else if (hasTurquoise) comboBadge = 'Antler + Turquoise';
else if (hasOpal) comboBadge = 'Antler + Opal';
else if (isElk)   comboBadge = 'Elk / Moose Antler';
---

<article class="card group flex flex-col overflow-hidden">
  <!-- Image -->
  <a href={localUrl}
    class="block relative overflow-hidden aspect-square bg-[#162114] shimmer-overlay"
    aria-label={`View ${product.title}`}>
    <img
      src={src}
      alt={alt}
      width="600"
      height="600"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </a>

  <!-- Card body -->
  <div class="flex flex-col flex-1 p-4 gap-3">
    <!-- Badges -->
    {(showBadge || comboBadge) && (
      <div class="flex flex-wrap gap-1.5">
        {showBadge && <span class="badge-antler">Genuine Antler</span>}
        {comboBadge && <span class="badge-antler">{comboBadge}</span>}
      </div>
    )}

    <!-- Title -->
    <h3 class="font-serif text-base leading-snug text-[#f0ede8] group-hover:text-[#d4b896] transition-colors duration-200 line-clamp-2">
      <a href={localUrl}>
        {product.title}
      </a>
    </h3>

    <!-- Engraving note -->
    <p class="text-xs text-[#7a7770] leading-snug">
      Free laser engraving up to 25 characters
    </p>

    <!-- CTA -->
    <div class="mt-auto pt-2 flex flex-col gap-2">
      <a
        href={localUrl}
        class="btn-outline w-full justify-center text-xs py-2"
        aria-label={`View details for ${product.title}`}
      >
        View Details
      </a>
      <a
        href={jbjUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold w-full justify-center text-xs py-2"
        aria-label={`Order ${product.title} at Jewelry by Johan`}
      >
        Order at Jewelry by Johan
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</article>