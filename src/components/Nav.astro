---
const navLinks = [
  { href: '/rings',     label: 'Rings' },
  { href: '/ring-sets', label: 'Ring Sets' },
  { href: '/earrings',  label: 'Earrings' },
  { href: '/pendants',  label: 'Pendants' },
  { href: '/cufflinks', label: 'Cufflinks' },
  { href: '/tie-clips', label: 'Tie Clips' },
  { href: '/unique',    label: 'Unique' },
  { href: '/custom',    label: 'Trophy Antler' },
];
const utilLinks = [
  { href: '/about',        label: 'About' },
  { href: '/sizing-guide', label: 'Sizing Guide' },
  { href: '/blog',         label: 'Blog' },
  { href: '/contact',      label: 'Contact' },
];
const pathname = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="nav-backdrop absolute inset-0 backdrop-blur-md border-b border-[#2e3d2d]"></div>
  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group flex-shrink-0" aria-label="Deer Antler Jewelry — Home">
        <img src="/favicon.svg" alt="" width="32" height="32"
          class="w-8 h-8 transition-transform duration-300 group-hover:scale-110" aria-hidden="true" />
        <span class="font-serif text-lg leading-tight hidden sm:block">
          <span class="nav-logo-main">Deer Antler</span>
          <span class="nav-logo-sub block -mt-1 font-sans font-normal tracking-widest uppercase" style="font-size:0.6rem">by Jewelry by Johan</span>
        </span>
      </a>

      <!-- Desktop collections dropdown -->
      <div class="hidden lg:flex items-center gap-1">
        <div class="relative group">
          <button
            class="nav-link flex items-center gap-1 px-3 py-2 text-sm font-sans transition-colors duration-200 rounded"
            aria-expanded="false" aria-haspopup="true">
            Collections
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
            <div class="nav-dropdown border border-[#2e3d2d] shadow-xl py-1">
              {navLinks.map((link) => (
                <a href={link.href}
                  class={`nav-dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-sans transition-colors duration-150 ${isActive(link.href) ? 'active' : ''}`}>
                  {link.href === '/custom' && <span class="w-1.5 h-1.5 rounded-full bg-[#b8860b] flex-shrink-0"></span>}
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
        {utilLinks.map((link) => (
          <a href={link.href}
            class={`nav-link px-3 py-2 text-sm font-sans transition-colors duration-200 rounded ${isActive(link.href) ? 'active' : ''}`}>
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop: search + theme toggle + CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <a href="/search" class="nav-icon-btn p-2 transition-colors duration-200" aria-label="Search">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="m21 21-4.35-4.35"/>
          </svg>
        </a>

        <!-- Theme toggle — desktop -->
        <button
          id="theme-toggle-desktop"
          class="theme-toggle nav-icon-btn p-2 transition-colors duration-200"
          aria-label="Toggle light/dark theme"
          title="Toggle light/dark theme">
          <!-- Moon icon — visible in dark mode -->
          <svg class="w-4 h-4 theme-icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <!-- Sun icon — visible in light mode -->
          <svg class="w-4 h-4 theme-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1"  x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1"  y1="12" x2="3"  y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>

        <a href="https://jewelrybyjohan.com/collections/deer-antler-rings"
          target="_blank" rel="noopener noreferrer"
          class="btn-gold text-xs px-4 py-2">View at Johan</a>
      </div>

      <!-- Mobile: search + theme toggle + hamburger -->
      <div class="flex lg:hidden items-center gap-1">
        <a href="/search" class="nav-icon-btn p-3 transition-colors" aria-label="Search">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="m21 21-4.35-4.35"/>
          </svg>
        </a>

        <!-- Theme toggle — mobile -->
        <button
          id="theme-toggle-mobile"
          class="theme-toggle nav-icon-btn p-3 transition-colors"
          aria-label="Toggle light/dark theme"
          title="Toggle light/dark theme">
          <svg class="w-5 h-5 theme-icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="w-5 h-5 theme-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1"  x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1"  y1="12" x2="3"  y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>

        <button id="mobile-menu-btn" class="nav-icon-btn p-3 transition-colors"
          aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg id="icon-hamburger" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu lg:hidden hidden border-t border-[#2e3d2d]" aria-label="Mobile navigation">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      <p class="nav-section-label px-3 pt-2 pb-1 text-[0.65rem] font-sans font-semibold tracking-[0.12em] uppercase">Collections</p>
      {navLinks.map((link) => (
        <a href={link.href}
          class={`mobile-nav-item flex items-center gap-2 px-3 py-2.5 text-sm font-sans rounded transition-colors duration-150 ${isActive(link.href) ? 'active' : ''}`}>
          {link.href === '/custom' && <span class="w-1.5 h-1.5 rounded-full bg-[#b8860b] flex-shrink-0"></span>}
          {link.label}
        </a>
      ))}
      <hr class="divider-gold my-3" />
      {utilLinks.map((link) => (
        <a href={link.href}
          class={`mobile-nav-item block px-3 py-2.5 text-sm font-sans rounded transition-colors duration-150 ${isActive(link.href) ? 'active' : ''}`}>
          {link.label}
        </a>
      ))}
      <div class="pt-3 pb-2">
        <a href="https://jewelrybyjohan.com/collections/deer-antler-rings"
          target="_blank" rel="noopener noreferrer"
          class="btn-gold w-full justify-center text-xs py-3">View at Jewelry by Johan</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-16"></div>

<script>
  // ── Mobile menu ────────────────────────────────────────────────────────────
  const btn       = document.getElementById('mobile-menu-btn');
  const menu      = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('shadow-lg', window.scrollY > 10);
  }, { passive: true });

  // ── Theme toggle ───────────────────────────────────────────────────────────
  function syncIcons(theme: string) {
    document.querySelectorAll<HTMLElement>('.theme-icon-moon').forEach(el => {
      el.style.display = theme === 'light' ? 'none' : '';
    });
    document.querySelectorAll<HTMLElement>('.theme-icon-sun').forEach(el => {
      el.style.display = theme === 'light' ? '' : 'none';
    });
  }

  function toggleTheme() {
    const isLight = document.documentElement.classList.contains('light');
    const next = isLight ? 'dark' : 'light';
    document.documentElement.classList.toggle('light', !isLight);
    try { localStorage.setItem('da-theme', next); } catch(_) {}
    syncIcons(next);
  }

  // Sync icons to whatever theme the anti-flash script already applied
  const stored = (() => { try { return localStorage.getItem('da-theme') ?? 'dark'; } catch(_) { return 'dark'; } })();
  syncIcons(stored);

  document.getElementById('theme-toggle-desktop')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
</script>